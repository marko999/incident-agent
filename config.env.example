# Copy this file to config.env and fill in your values
# cp config.env.example config.env

# Azure
AZURE_SUBSCRIPTION_ID="your-subscription-id"
AZURE_REGION="eastus"
RESOURCE_GROUP="rg-incident-agent"
CLUSTER_NAME="aks-incident-demo"

# Azure OpenAI
AZURE_AI_PROJECT_ENDPOINT="https://your-resource.cognitiveservices.azure.com/"
AZURE_OPENAI_RESPONSES_DEPLOYMENT_NAME="your-deployment-name"

# GitHub repo where the agent will create PRs (format: owner/repo)
GITHUB_REPO="your-org/incident-agent"

# AKS node config
NODE_VM_SIZE="Standard_B2s"
NODE_COUNT=2

# Azure Container Registry (created by 03-deploy-app.sh)
ACR_NAME="your-acr-name"

# Isolated kubeconfig — NEVER use your default kubeconfig
export KUBECONFIG="$HOME/.kube/aks-incident-demo.config"
