# Copy this file to config.env and fill in your values
# cp config.env.example config.env

# Azure
AZURE_SUBSCRIPTION_ID="your-subscription-id"
AZURE_REGION="canadacentral"
RESOURCE_GROUP="rg-incident-agent"
CLUSTER_NAME="aks-incident-demo"

# GitHub repo where the agent will create PRs (format: owner/repo)
GITHUB_REPO="your-github-username/incident-agent"

# Node size (B2s is cheapest, sufficient for demo)
NODE_VM_SIZE="Standard_B2s"
NODE_COUNT=2

# Isolated kubeconfig - NEVER touch other clusters
export KUBECONFIG="$HOME/.kube/aks-incident-demo.config"
